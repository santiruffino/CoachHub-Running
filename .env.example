# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=

# App URL
# APP_URL is used server-side; NEXT_PUBLIC_APP_URL is the browser-exposed variant
# used as a fallback when building absolute links (e.g. team invite links).
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Web Push (VAPID) — generate with `npx web-push generate-vapid-keys`
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@endurix.app

# Strava OAuth
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_OAUTH_STATE_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3000/strava/callback

# Strava webhook
STRAVA_WEBHOOK_VERIFY_TOKEN=
STRAVA_SUBSCRIPTION_ID=
STRAVA_WEBHOOK_SHARED_SECRET=
STRAVA_WEBHOOK_RATE_LIMIT_WINDOW_MS=
STRAVA_WEBHOOK_RATE_LIMIT_MAX_REQUESTS=

# Garmin (opt-in pilot). Required to enable the Garmin integration: the app
# refuses to encrypt/decrypt Garmin tokens without it (isGarminConfigured()).
# Must decode to 32 bytes (256-bit). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
GARMIN_TOKEN_ENC_KEY=

# Cron jobs (Vercel). Cron routes require `Authorization: Bearer $CRON_SECRET`.
# Set the same value in the Vercel cron configuration.
CRON_SECRET=

# Optional runtime tuning
LOG_LEVEL=
API_RATE_LIMIT_WINDOW_MS=
API_RATE_LIMIT_MAX_REQUESTS=

# Sentry (shared DSN + client options)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0

# Optional Sentry build-time values (source map uploads)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Resend (email)
RESEND_API_KEY=

# Wishlist form notification email (Resend)
# Where WISHLIST_FROM_EMAIL must be a verified sender/domain in your Resend account.
# WISHLIST_NOTIFY_EMAIL is the recipient who gets pinged on each new signup.
WISHLIST_FROM_EMAIL=Endurix Wishlist <wishlist@endurix.app>
WISHLIST_NOTIFY_EMAIL=
