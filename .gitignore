# which variables are required.
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# images
opencode.json

# Sentry Config File
.env.sentry-build-plugin

# Design sync — build artifacts (committed: .design-sync/config.json, conventions.md, previews/, NOTES.md, src/ds-index.ts)
.ds-sync/
ds-bundle/
.design-sync/.cache/
.design-sync/node_modules/
.env.local

